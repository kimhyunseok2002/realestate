# SurviMap 환경변수 예시
# ------------------------------------------------------------------
# 실제 키는 이 파일이 아니라 .env 에 넣으세요. (.env 는 .gitignore 에 있어 git/Vercel에 올라가지 않습니다)
#   1) 이 파일을 복사:  cp .env.example .env
#   2) .env 의 OPENAI_API_KEY 를 본인 키로 채우기
#   3) python3 run.py 로 실행하면 자동 로드됩니다
# 배포(Vercel)는 이 파일 대신 Vercel 대시보드 > Settings > Environment Variables 에 OPENAI_API_KEY 를 등록하세요.

# OpenAI API 키 (필수). 없으면 LLM 대신 규칙기반 템플릿으로 자동 폴백합니다.
OPENAI_API_KEY=sk-여기에_본인_키를_넣으세요

# (선택) 사용할 모델 — 기본 gpt-4o-mini. gpt-4o, gpt-4.1-mini 등으로 교체 가능
# SANGKWON_LLM_MODEL=gpt-4o-mini

# (선택) 응답 타임아웃(초) — 기본 60
# SANGKWON_LLM_TIMEOUT=60

# (선택) OpenAI 호환 게이트웨이/프록시 URL — 기본 https://api.openai.com/v1
# OPENAI_BASE_URL=https://api.openai.com/v1

# (선택) 한국부동산원 R-ONE OpenAPI 인증키.
#   임대료·공실률 실데이터 스냅샷(backend/realdata/rone_lease.json)을 재생성할 때만 필요합니다.
#   발급: https://www.reb.or.kr/r-one → 오픈API → 인증키 신청
#   재생성:  python3 -m backend.realdata.build_rone
# RONE_API_KEY=여기에_R-ONE_인증키
